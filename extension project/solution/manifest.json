{
  "name": "Workday Autofill final version",
  "description": "Helps students fill out Workday job applications",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "extension-logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["extension-logo.png"],
      "matches": ["*://*.myworkdayjobs.com/*"]
    }
  ],
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": ["*://*.myworkdayjobs.com/*"],
      "js": [
        "styles.js",
        "util.js",
        "drivers/workday.js",
        "helpers/fillData.js",
        "helpers/applyStyles.js",
        "helpers/runAutofillSequence.js",
        "helpers/showConfirmationBanner.js",
        "helpers/startAutofill.js",
        "main.js"
      ],
      "run_at": "document_idle"
    }
  ]
}